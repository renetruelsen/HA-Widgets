<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HaWidgets" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar" />

    <style name="Theme.HaWidgets.Dialog" parent="@android:style/Theme.DeviceDefault.Light.Dialog.NoActionBar" />

    <style name="Theme.HaWidgets.Translucent" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <!-- Skip the starting-window/splash when launched from a widget tap. -->
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Overstyrer glance-appwidget-bibliotekets tomme style-hook af samme navn (app-resurser
         vinder over bibliotekets ved merge). Glance's LazyColumn renderes som en klassisk
         ListView (glance_list.xml i biblioteket), hvis brede system-scrollbar skæmmede
         multi-entity widgetten — her gøres den slank, afrundet og hurtigt-fadende. -->
    <style name="Glance.AppWidget.List" parent="">
        <item name="android:scrollbarSize">3dp</item>
        <item name="android:scrollbarThumbVertical">@drawable/glance_scrollbar_thumb</item>
        <item name="android:scrollbarDefaultDelayBeforeFade">400</item>
        <item name="android:scrollbarFadeDuration">400</item>
    </style>
</resources>
