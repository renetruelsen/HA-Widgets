<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Synlighed af apps med en launcher-genvej (Android 11+) til "Åbn app"-handlingen.
         Undgår den Play-restriktede QUERY_ALL_PACKAGES — vi behøver kun apps med et ikon. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".HaWidgetsApp"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HaWidgets"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.HaWidgets">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".web.WebViewActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.HaWidgets.Translucent" />

        <activity
            android:name=".widget.ShortcutWidgetConfigActivity"
            android:exported="true"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:theme="@style/Theme.HaWidgets">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.ShortcutWidgetReceiver"
            android:label="@string/shortcut_widget_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/shortcut_widget_info" />
        </receiver>

        <!-- Multi-entity -->
        <activity
            android:name=".widget.multientity.MultiEntityWidgetConfigActivity"
            android:exported="true"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:theme="@style/Theme.HaWidgets">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
        <receiver
            android:name=".widget.multientity.MultiEntityWidgetReceiver"
            android:label="@string/multi_entity_widget_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/multi_entity_widget_info" />
        </receiver>

        <activity
            android:name=".widget.common.RangeControlActivity"
            android:exported="false"
            android:theme="@style/Theme.HaWidgets.Dialog"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.common.TextControlActivity"
            android:exported="false"
            android:theme="@style/Theme.HaWidgets.Dialog"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.common.NumberInputActivity"
            android:exported="false"
            android:theme="@style/Theme.HaWidgets.Dialog"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.common.DateTimeControlActivity"
            android:exported="false"
            android:theme="@style/Theme.HaWidgets.Dialog"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.common.ConfirmActionActivity"
            android:exported="false"
            android:theme="@style/Theme.HaWidgets.Dialog"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.common.AppLaunchActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <!-- Eksponerer den eksporterede config-fil midlertidigt til systemets share-sheet. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="dk.rtr.hawidgets.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
